        },
        "e15dcbd0-bf98-4d71-abed-51a2799236e6": {
          "type": "image",
          "settings": {
            "icon_select": "100",
            "text": "<p>\"Mokosh Face Cream is a skincare hero. It absorbs quickly, leaving my skin supple and glowing. A must for anyone craving a natural, effective moisturizer.\"</p>",
